<script>
  // ─── Mobile collapse for resource lists ───
  // On small screens, cards start collapsed (except first).
  const mq = window.matchMedia('(max-width: 760px)');
  const cards = document.querySelectorAll('.card');

  function applyCollapseState(){
    cards.forEach((card, idx) => {
      if (mq.matches){
        // collapse all except the first
        if (idx === 0) card.classList.remove('collapsed');
        else card.classList.add('collapsed');
      } else {
        card.classList.remove('collapsed');
      }
    });
  }
  applyCollapseState();
  mq.addEventListener('change', applyCollapseState);

  // toggle handlers
  document.querySelectorAll('.toggle-res').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.card');
      const collapsed = card.classList.toggle('collapsed');
      btn.setAttribute('aria-expanded', String(!collapsed));
    });
  });

  // ─── Progress pill: scrollspy ───
  const pills = document.querySelectorAll('.progress .pill');
  const moduleEls = Array.from(document.querySelectorAll('.card[id^="m"]'));
  const io = new IntersectionObserver((entries) => {
    entries.forEach(en => {
      if (en.isIntersecting){
        const id = en.target.id;
        pills.forEach(p => {
          p.classList.toggle('active', p.getAttribute('href') === '#' + id);
        });
      }
    });
  }, { rootMargin: '-40% 0px -50% 0px', threshold: 0 });
  moduleEls.forEach(el => io.observe(el));

  // smooth scroll
  pills.forEach(p => {
    p.addEventListener('click', (e) => {
      const href = p.getAttribute('href');
      if (href && href.startsWith('#')){
        e.preventDefault();
        const target = document.querySelector(href);
        if (target){
          // expand the card if collapsed (mobile)
          target.classList.remove('collapsed');
          const tog = target.querySelector('.toggle-res');
          if (tog) tog.setAttribute('aria-expanded', 'true');
          const top = target.getBoundingClientRect().top + window.pageYOffset - 12;
          window.scrollTo({top, behavior:'smooth'});
        }
      }
    });
  });
</script>

<!-- ─── Tweaks panel ─── -->
<script src="https://unpkg.com/react@18.3.1/umd/react.development.js" integrity="sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L" crossorigin="anonymous"></script>
<script src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js" integrity="sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm" crossorigin="anonymous"></script>
<script src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js" integrity="sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y" crossorigin="anonymous"></script>
<script type="text/babel" src="../tweaks-panel.jsx"></script>
<div id="tweaks-root"></div>
<script type="text/babel">
  const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{
    "mood": "warrior",
    "voice": "gravitas",
    "ornament": "ritual"
  }/*EDITMODE-END*/;

  function applyTweaks(t){
    const html = document.documentElement;
    html.setAttribute('data-mood', t.mood);
    html.setAttribute('data-voice', t.voice);
    html.setAttribute('data-ornament', t.ornament);
  }

  function TweaksApp(){
    const [t, setTweak] = useTweaks(TWEAK_DEFAULTS);
    React.useEffect(() => { applyTweaks(t); }, [t.mood, t.voice, t.ornament]);

    return (
      <TweaksPanel title="Tweaks · DPL I">
        <TweakSection label="Mood" />
        <TweakRadio
          label="Palette"
          value={t.mood}
          options={[
            {value:'warrior',  label:'Warrior'},
            {value:'temple',   label:'Temple'},
            {value:'oceanic',  label:'Oceanic'},
          ]}
          onChange={(v) => setTweak('mood', v)}
        />
        <TweakSection label="Voice" />
        <TweakRadio
          label="Headline tone"
          value={t.voice}
          options={[
            {value:'gravitas',     label:'Gravitas'},
            {value:'field-guide',  label:'Field guide'},
            {value:'neutral',      label:'Neutral'},
          ]}
          onChange={(v) => setTweak('voice', v)}
        />
        <TweakSection label="Ornament" />
        <TweakRadio
          label="Ritual density"
          value={t.ornament}
          options={[
            {value:'sober',       label:'Sober'},
            {value:'ritual',      label:'Ritual'},
            {value:'ceremonial',  label:'Ceremonial'},
          ]}
          onChange={(v) => setTweak('ornament', v)}
        />
      </TweaksPanel>
    );
  }

  // Apply defaults BEFORE mount so first paint matches saved tweaks
  applyTweaks(TWEAK_DEFAULTS);
  ReactDOM.createRoot(document.getElementById('tweaks-root')).render(<TweaksApp />);
</script>

</body>
</html>

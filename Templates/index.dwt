<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="theme-color" content="#0D0D0D" />
<!-- TemplateBeginEditable name="doctitle" -->
<title>Diplomado de Liderazgo Efectivo I · Guerreros de la Luz</title>
<!-- TemplateEndEditable -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,500;0,600;1,300;1,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0D0D0D;
    --bg-elev:#121212;
    --gold:#f2ad00;
    --gold-soft:#c8a951;
    --blue-accent:#004f94;
    --card:#052e67;
    --card-deep:#04244f;
    --text:#ffffff;
    --text-mute:#878786;
    --hairline:rgba(200,169,81,0.20);
    --hairline-strong:rgba(242,173,0,0.55);
    --shadow:0 4px 24px rgba(200,169,81,0.08);
    --radius-card:14px;
    --radius-btn:8px;

    /* These three are overridden by data-mood/voice/ornament */
    --mood-bg-grad-1: rgba(242,173,0,0.06);
    --mood-bg-grad-2: rgba(0,79,148,0.10);
    --font-display: 'Playfair Display', serif;
    --font-display-italic-style: italic;
    --ornament-glyph-opacity: 0.18;
    --ornament-glyph-size: 22px;
    --ornament-mod-num-size: 36px;
    --ornament-rule-display: block;
  }

  /* ─── MOOD variants ─── */
  html[data-mood="temple"]{
    --bg:#14100a;
    --gold:#e8b34a;
    --gold-soft:#c8a45a;
    --blue-accent:#7a2418;
    --card:#3a1d10;
    --card-deep:#2a140b;
    --hairline:rgba(232,179,74,0.22);
    --hairline-strong:rgba(232,179,74,0.55);
    --shadow:0 4px 24px rgba(232,179,74,0.10);
    --mood-bg-grad-1: rgba(232,179,74,0.07);
    --mood-bg-grad-2: rgba(184,76,42,0.12);
  }
  html[data-mood="oceanic"]{
    --bg:#070d18;
    --gold:#9bb6d6;
    --gold-soft:#7a93b3;
    --blue-accent:#0a3a78;
    --card:#0a2548;
    --card-deep:#061a36;
    --text:#eaf1fb;
    --hairline:rgba(155,182,214,0.22);
    --hairline-strong:rgba(155,182,214,0.55);
    --shadow:0 4px 24px rgba(0,79,148,0.18);
    --mood-bg-grad-1: rgba(0,79,148,0.18);
    --mood-bg-grad-2: rgba(155,182,214,0.06);
  }

  /* ─── VOICE variants ─── */
  html[data-voice="field-guide"]{
    --font-display: 'Cormorant Garamond', serif;
    --font-display-italic-style: italic;
  }
  html[data-voice="field-guide"] .hero h1,
  html[data-voice="field-guide"] .card-title,
  html[data-voice="field-guide"] .submit h2,
  html[data-voice="field-guide"] .section-head h2{
    font-weight:500;
    letter-spacing:-0.005em;
  }
  html[data-voice="field-guide"] .hero h1{font-size: clamp(34px, 7.2vw, 68px); line-height:1.02}

  html[data-voice="neutral"]{
    --font-display: 'Inter', sans-serif;
    --font-display-italic-style: italic;
  }
  html[data-voice="neutral"] .hero h1,
  html[data-voice="neutral"] .card-title,
  html[data-voice="neutral"] .submit h2,
  html[data-voice="neutral"] .section-head h2{
    font-weight:700;
    letter-spacing:-0.025em;
  }
  html[data-voice="neutral"] .hero h1 em,
  html[data-voice="neutral"] .submit h2 em{font-style:normal;text-decoration:underline;text-decoration-color:var(--gold);text-decoration-thickness:2px;text-underline-offset:6px}

  /* Apply --font-display to the actual headings */
  .hero h1,
  .card-title,
  .submit h2,
  .section-head h2{font-family: var(--font-display)}
  .hero h1 em,
  .submit h2 em{font-style: var(--font-display-italic-style)}

  /* ─── ORNAMENT variants ─── */
  html[data-ornament="sober"]{
    --ornament-glyph-opacity: 0;
    --ornament-mod-num-size: 28px;
    --ornament-rule-display: none;
  }
  html[data-ornament="sober"] .hero::before{display:none}
  html[data-ornament="sober"] footer .mark{display:none}
  html[data-ornament="sober"] .brand .mark{opacity:.5}

  html[data-ornament="ceremonial"]{
    --ornament-glyph-opacity: 0.34;
    --ornament-glyph-size: 32px;
    --ornament-mod-num-size: 52px;
  }
  html[data-ornament="ceremonial"] .hero::before{font-size:42px}
  html[data-ornament="ceremonial"] .card{padding-top:30px}
  html[data-ornament="ceremonial"] .card::after{
    content:"";
    position:absolute;left:22px;top:78px;
    width:32px;height:1px;background:var(--gold);opacity:.6;
  }
  html[data-ornament="ceremonial"] .hero h1{
    text-shadow: 0 0 30px rgba(242,173,0,0.06);
  }
  html[data-ornament="ceremonial"] .card-title::before{
    content:"";display:block;width:24px;height:1px;background:var(--gold);opacity:.5;
    margin:0 0 10px;
  }

  *{box-sizing:border-box}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
  body{
    font-family:'Inter',system-ui,-apple-system,sans-serif;
    font-size:16px;
    line-height:1.55;
    min-height:100vh;
    background:
      radial-gradient(1100px 600px at 50% -200px, var(--mood-bg-grad-1), transparent 60%),
      radial-gradient(800px 500px at 90% 20%, var(--mood-bg-grad-2), transparent 70%),
      var(--bg);
    background-attachment: fixed;
  }
  a{color:inherit;text-decoration:none}
  button{font-family:inherit}

  /* ─── Layout shell ─── */
  .wrap{
    max-width:1180px;
    margin:0 auto;
    padding: clamp(20px, 4vw, 40px) clamp(16px, 4vw, 32px) 80px;
  }

  /* ─── Header ─── */
  .topbar{
    display:flex;align-items:center;justify-content:space-between;
    padding-top:8px;
    margin-bottom: clamp(28px, 6vw, 48px);
  }
  .brand{
    display:flex;align-items:center;gap:10px;
    color:var(--gold);
    font-weight:700;
    font-size:11px;
    letter-spacing:0.22em;
    text-transform:uppercase;
  }
  .brand .mark{
    font-size:18px;line-height:1;
    color:var(--gold);
    text-shadow:0 0 18px rgba(242,173,0,0.35);
  }
  .topbar .year{
    color:var(--text-mute);
    font-family:'JetBrains Mono',monospace;
    font-size:11px;
    letter-spacing:0.15em;
  }

  /* ─── Hero ─── */
  .hero{
    text-align:center;
    padding: clamp(20px, 5vw, 56px) 0 clamp(32px, 6vw, 56px);
    border-bottom:1px solid var(--hairline);
    margin-bottom: clamp(36px, 6vw, 64px);
    position:relative;
  }
  .hero::before{
    content:"◈";
    display:block;
    color:var(--gold);
    font-size:28px;
    margin-bottom:18px;
    text-shadow:0 0 24px rgba(242,173,0,0.45);
  }
  .hero h1{
    font-weight:700;
    margin:0 0 14px;
    font-size: clamp(28px, 6vw, 56px);
    line-height:1.05;
    letter-spacing:-0.01em;
    text-wrap:balance;
  }
  .hero h1 em{
    font-style:italic;
    color:var(--gold);
    font-weight:600;
  }
  .hero .sub{
    color:var(--text-mute);
    font-size: clamp(15px, 2vw, 18px);
    max-width:560px;
    margin:0 auto 28px;
  }
  .hero .sub strong{color:#d6d6d4;font-weight:500}

  /* Progress pills */
  .progress{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    flex-wrap:wrap;
    padding-top: 4px;
  }
  .progress .pill{
    display:inline-flex;align-items:center;gap:8px;
    padding:6px 12px 6px 8px;
    border:1px solid var(--hairline);
    border-radius:999px;
    background:rgba(255,255,255,0.02);
    font-family:'JetBrains Mono',monospace;
    font-size:11px;
    color:var(--text-mute);
    letter-spacing:0.06em;
    transition:all .2s ease;
    cursor:pointer;
  }
  .progress .pill .dot{
    width:8px;height:8px;border-radius:50%;
    background:var(--gold);
    opacity:0.35;
  }
  .progress .pill:hover{border-color:var(--hairline-strong);color:#fff}
  .progress .pill.active .dot{opacity:1;box-shadow:0 0 10px rgba(242,173,0,0.7)}
  .progress .pill.active{color:#fff;border-color:var(--hairline-strong)}
  .progress .sep{
    width:18px;height:1px;background:var(--hairline);
  }

  /* ─── Section heading ─── */
  .section-head{
    display:flex;align-items:baseline;gap:14px;
    margin: 8px 0 22px;
  }
  .section-head .kicker{
    color:var(--gold);
    font-family:'JetBrains Mono',monospace;
    font-size:11px;
    letter-spacing:0.2em;
    text-transform:uppercase;
  }
  .section-head .rule{flex:1;height:1px;background:var(--hairline);display:var(--ornament-rule-display)}
  .section-head h2{
    font-weight:700;
    font-size: clamp(20px, 3vw, 26px);
    margin:0;
  }

  /* ─── Module grid ─── */
  .grid{
    display:flex;
    flex-wrap:wrap;
    gap: 20px;
    margin-bottom: 56px;
  }
  .card{
    flex: 1 1 320px;
    min-width:0;
    background: linear-gradient(180deg, var(--card) 0%, var(--card-deep) 100%);
    border:1px solid var(--hairline);
    border-radius:var(--radius-card);
    box-shadow: var(--shadow);
    padding: 24px 22px 22px;
    display:flex;flex-direction:column;gap:16px;
    position:relative;
    overflow:hidden;
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
  }
  .card::before{
    /* corner glyph */
    content:"◈";
    position:absolute;
    top:18px;right:20px;
    color:var(--gold);
    opacity:var(--ornament-glyph-opacity);
    font-size:var(--ornament-glyph-size);
  }
  .card:hover{
    border-color:var(--hairline-strong);
    box-shadow: 0 6px 30px rgba(242,173,0,0.14);
  }

  .card-head{
    display:flex;align-items:flex-start;gap:14px;
    padding-right:30px; /* leave room for glyph */
  }
  .mod-num{
    font-family:'JetBrains Mono',monospace;
    font-weight:700;
    font-size: var(--ornament-mod-num-size);
    line-height:0.9;
    color:var(--gold);
    letter-spacing:-0.02em;
    flex-shrink:0;
  }
  .mod-num small{
    display:block;
    font-size:10px;
    letter-spacing:0.2em;
    color:var(--text-mute);
    margin-top:6px;
    font-weight:500;
  }
  .card-title{
    font-weight:700;
    font-size: 22px;
    line-height:1.18;
    margin:2px 0 0;
    color:#fff;
    text-wrap:balance;
  }

  .concepts{
    color:#cdd5e2;
    font-size:13px;
    line-height:1.55;
  }
  .concepts .dot{color:var(--gold);margin:0 6px;opacity:0.7}

  .badge{
    display:inline-flex;align-items:center;gap:6px;
    align-self:flex-start;
    padding:5px 10px;
    border-radius:999px;
    font-size:11px;
    font-weight:600;
    letter-spacing:0.08em;
    text-transform:uppercase;
    background:rgba(242,173,0,0.10);
    color:var(--gold);
    border:1px solid rgba(242,173,0,0.25);
  }
  .badge.special{
    background:rgba(0,79,148,0.35);
    color:#cfe2ff;
    border-color:rgba(120,170,230,0.45);
  }
  .badge .bolt{font-size:10px}

  .divider{
    height:1px;
    background: linear-gradient(90deg, transparent, var(--hairline) 20%, var(--hairline) 80%, transparent);
    margin: 2px -22px;
  }

  /* ─── Resource buttons ─── */
  .res{
    display:flex;flex-direction:column;gap:8px;
  }
  .res-btn{
    display:flex;align-items:center;gap:12px;
    width:100%;
    min-height:48px;
    padding: 10px 14px;
    border-radius: var(--radius-btn);
    background: rgba(255,255,255,0.04);
    border:1px solid rgba(255,255,255,0.07);
    color:#f5f5f3;
    font-size:14px;
    font-weight:500;
    text-align:left;
    cursor:pointer;
    transition: all .18s ease;
    font-family:inherit;
  }
  .res-btn:hover{
    border-color: var(--hairline-strong);
    background: rgba(242,173,0,0.06);
    transform: translateY(-1px);
  }
  .res-btn .ico{
    display:inline-flex;align-items:center;justify-content:center;
    width:30px;height:30px;
    border-radius:8px;
    background:rgba(242,173,0,0.10);
    color:var(--gold);
    flex-shrink:0;
  }
  .res-btn .ico svg{width:16px;height:16px;display:block}
  .res-btn .label{flex:1;line-height:1.25}
  .res-btn .meta{
    color:var(--text-mute);
    font-family:'JetBrains Mono',monospace;
    font-size:10px;
    letter-spacing:0.06em;
    text-transform:uppercase;
  }
  .res-btn .arrow{color:var(--text-mute);opacity:.7;transition:transform .2s ease}
  .res-btn:hover .arrow{color:var(--gold);opacity:1;transform:translateX(2px)}

  /* Special variants */
  .res-btn.part2{
    border-color: rgba(120,170,230,0.40);
    background: linear-gradient(180deg, rgba(0,79,148,0.35), rgba(0,79,148,0.18));
  }
  .res-btn.part2 .ico{background:rgba(120,170,230,0.20);color:#cfe2ff}
  .res-btn.part2 .pill-tag{
    display:inline-block;
    padding:3px 8px;
    border-radius:999px;
    background:rgba(120,170,230,0.25);
    color:#e3eeff;
    font-size:10px;
    font-weight:700;
    letter-spacing:0.12em;
    margin-left:6px;
  }
  .res-btn.outline{
    background: transparent;
    border:1px dashed var(--hairline);
  }
  .res-btn.outline:hover{
    border-style:solid;
    background: rgba(242,173,0,0.04);
  }
  .res-btn.outline .ico{background:transparent;border:1px solid var(--hairline)}

  /* Featured: digital cuadernillo (interactive HTML) */
  .res-btn.featured{
    background: linear-gradient(180deg, rgba(242,173,0,0.16), rgba(242,173,0,0.06));
    border:1px solid rgba(242,173,0,0.45);
    color:#fff8e6;
  }
  .res-btn.featured .ico{
    background:var(--gold);color:#1a1300;
  }
  .res-btn.featured:hover{
    background: linear-gradient(180deg, rgba(242,173,0,0.22), rgba(242,173,0,0.10));
    border-color: var(--gold);
    box-shadow: 0 4px 18px rgba(242,173,0,0.18);
  }
  .res-btn.featured .meta{color:#f2ad00;opacity:.85}
  .res-btn .tag-new{
    display:inline-block;
    padding:2px 7px;
    border-radius:999px;
    background:rgba(0,79,148,0.55);
    color:#dbe8fc;
    font-family:'JetBrains Mono',monospace;
    font-size:9px;
    font-weight:700;
    letter-spacing:0.14em;
    margin-left:8px;
    vertical-align:1px;
  }

  /* Mobile collapse toggle */
  .toggle-res{
    display:none; /* shown only on small screens */
    align-items:center;justify-content:space-between;gap:10px;
    margin-top:4px;
    padding: 10px 12px;
    width:100%;
    background:rgba(242,173,0,0.07);
    border:1px solid var(--hairline);
    color:var(--gold);
    border-radius:var(--radius-btn);
    font-size:13px;
    font-weight:600;
    letter-spacing:0.04em;
    cursor:pointer;
  }
  .toggle-res .chev{transition:transform .2s ease}
  .card.collapsed .res{display:none}
  .card.collapsed .toggle-res .chev{transform:rotate(0deg)}
  .toggle-res .chev{transform:rotate(180deg)}

  /* ─── Submit homework section ─── */
  .submit{
    margin: 64px 0 40px;
    padding: clamp(28px, 4vw, 44px) clamp(24px, 4vw, 40px);
    border:1px solid var(--hairline);
    border-radius: 18px;
    background:
      radial-gradient(600px 200px at 50% 0%, rgba(242,173,0,0.10), transparent 60%),
      linear-gradient(180deg, rgba(242,173,0,0.04), rgba(0,0,0,0));
    text-align:center;
  }
  .submit h2{
    font-weight:700;
    font-size: clamp(22px, 3.4vw, 32px);
    margin:0 0 10px;
    text-wrap:balance;
  }
  .submit h2 em{font-style:italic;color:var(--gold)}
  .submit p{
    color:var(--text-mute);
    margin:0 auto 24px;
    max-width:520px;
    font-size:15px;
  }
  .cta{
    display:inline-flex;align-items:center;justify-content:center;gap:12px;
    width:100%;
    max-width:460px;
    min-height:60px;
    padding: 16px 24px;
    background:var(--gold);
    color:#1a1300;
    font-weight:700;
    font-size:16px;
    letter-spacing:0.04em;
    border:none;
    border-radius: 12px;
    cursor:pointer;
    box-shadow: 0 10px 30px rgba(242,173,0,0.25), inset 0 1px 0 rgba(255,255,255,0.30);
    transition: transform .15s ease, box-shadow .2s ease;
    font-family:inherit;
  }
  .cta:hover{transform:translateY(-2px);box-shadow:0 14px 36px rgba(242,173,0,0.35), inset 0 1px 0 rgba(255,255,255,0.30)}
  .cta svg{width:20px;height:20px}
  .submit .alt{
    margin-top:18px;
    font-size:13px;
    color:var(--text-mute);
  }
  .submit .alt a{
    color:#bfbfbe;
    border-bottom:1px solid var(--hairline);
    padding-bottom:1px;
    transition:color .15s, border-color .15s;
  }
  .submit .alt a:hover{color:var(--gold);border-color:var(--hairline-strong)}

  /* ─── Footer ─── */
  footer{
    text-align:center;
    color:var(--text-mute);
    font-size:12px;
    letter-spacing:0.08em;
    padding-top:32px;
    border-top:1px solid var(--hairline);
  }
  footer .mark{
    display:block;
    color:var(--gold);
    font-size:18px;
    margin-bottom:10px;
    text-shadow:0 0 14px rgba(242,173,0,0.3);
  }

  /* ─── Responsive ─── */
  @media (max-width: 760px){
    .card{flex: 1 1 100%}
    .progress .sep{display:none}
    .progress{gap:6px}
    .toggle-res{display:flex}
    /* By default collapsed on mobile — JS sets state */
  }
  @media (max-width: 480px){
    .res-btn{padding:12px 14px;min-height:52px}
    .cta{font-size:15px}
    .card-title{font-size:20px}
    .mod-num{font-size:32px}
    .topbar .year{display:none}
  }

  /* Focus visibility */
  :focus-visible{outline:2px solid var(--gold);outline-offset:2px;border-radius:6px}

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce){
    *{transition:none !important;animation:none !important}
  }
</style>
<!-- TemplateBeginEditable name="head" -->
<!-- TemplateEndEditable -->
</head>
<body>

<div class="wrap">

  <!-- TOP BAR -->
  <header class="topbar">
    <div class="brand">
      <span class="mark">◈</span>
      <span>Guerreros de la Luz</span>
    </div>
    <div class="year">DPL · I — 2026</div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <h1>Diplomado de <em>Liderazgo Efectivo</em> I</h1>
    <p class="sub">Tu proceso. Tu responsabilidad. <strong>Tu camino.</strong></p>

    <nav class="progress" aria-label="Progreso del diplomado">
      <a href="#m1" class="pill"><span class="dot"></span>M1</a>
      <span class="sep" aria-hidden="true"></span>
      <a href="#m2" class="pill"><span class="dot"></span>M2</a>
      <span class="sep" aria-hidden="true"></span>
      <a href="#m3" class="pill"><span class="dot"></span>M3</a>
      <span class="sep" aria-hidden="true"></span>
      <a href="#m4" class="pill"><span class="dot"></span>M4</a>
      <span class="sep" aria-hidden="true"></span>
      <a href="#m5" class="pill"><span class="dot"></span>M5</a>
      <span class="sep" aria-hidden="true"></span>
      <a href="#m6" class="pill"><span class="dot"></span>M6</a>
    </nav>
  </section>

  <!-- MODULES SECTION -->
  <div class="section-head">
    <span class="kicker">06 Módulos</span>
    <h2>El camino completo</h2>
    <span class="rule" aria-hidden="true"></span>
  </div>

  <div class="grid" id="modules">

    <!-- M1 -->
    <article class="card" id="m1">
      <div class="card-head">
        <div class="mod-num">01<small>Módulo</small></div>
        <div>
          <h3 class="card-title">El Liderazgo Comienza Contigo</h3>
        </div>
      </div>
      <p class="concepts">Honestidad extrema <span class="dot">·</span> Patrón personal <span class="dot">·</span> Presencia</p>
      <span class="badge">Base del proceso</span>

